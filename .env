# ===========================================
# Personal Finance Manager - Docker Compose Environment Variables
# ===========================================

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# Имя базы данных
POSTGRES_DB=pfm

# Имя пользователя базы данных
POSTGRES_USER=postgres

# Пароль пользователя базы данных
POSTGRES_PASSWORD=postgres

# ===========================================
# BACKEND CONFIGURATION
# ===========================================
# Режим работы: 'development' | 'production'
NODE_ENV=development

# Хост базы данных (имя сервиса в docker-compose)
DB_HOST=db

# Порт базы данных
DB_PORT=5432

# Имя базы данных
DB_NAME=pfm

# Имя пользователя базы данных
DB_USERNAME=postgres

# Пароль пользователя базы данных
DB_PASSWORD=postgres

# Секретный ключ для JWT
# ВАЖНО: Изменить в production на безопасный ключ
JWT_SECRET=your-secret-key-change-in-production

# Ключи для access и refresh токенов
ACCESS_TOKEN_SECRET=access-secret-key-change-in-production
REFRESH_TOKEN_SECRET=refresh-secret-key-change-in-production

# CORS
CORS_ORIGIN=*

# Режим работы (docker - для docker-compose)
SPRING_PROFILES_ACTIVE=docker

# ===========================================
# FRONTEND CONFIGURATION
# ===========================================
# Режим работы приложения: 'development' | 'production'
APP_MODE=production

# ===========================================
# PORTS CONFIGURATION
# ===========================================
# Порт для frontend (nginx)
FRONTEND_PORT=80

# Порт для backend
BACKEND_PORT=8080

# Порт для adminer
ADMINER_PORT=8081

# Порт для базы данных
DB_EXTERNAL_PORT=5432