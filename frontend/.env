# ===========================================
# Personal Finance Manager - Frontend Environment Variables
# ===========================================

# ===========================================
# APPLICATION MODE
# ===========================================
# Режим работы приложения: 'development' | 'production'
# development - используется для разработки, позволяет моковые данные и гостевой доступ
# production - production режим, обязательная авторизация
VITE_APP_MODE=development

# ===========================================
# API CONFIGURATION
# ===========================================
# Базовый URL API бэкенда
# В development используется относительный путь /api
# В production можно указать полный URL
VITE_API_BASE_URL=/api

# ===========================================
# DEVELOPMENT OPTIONS
# ===========================================
# Использовать моковые данные (только для development)
# true - использовать моковые данные
# false - использовать реальный API бэкенда
VITE_USE_MOCK_DATA=false

# Задержка для имитации API запросов (в миллисекундах)
VITE_MOCK_DELAY=1000

# ===========================================
# BUILD OPTIONS
# ===========================================
# Порт для dev сервера (по умолчанию 5173)
# VITE_PORT=5173

# Публичный путь для продакшн сборки
# VITE_BASE_URL=/
