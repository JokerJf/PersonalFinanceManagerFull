# ===========================================
# Personal Finance Manager - Backend Environment Variables
# ===========================================

# ===========================================
# SERVER CONFIGURATION
# ===========================================
# Порт для запуска сервера
PORT=8080

# Режим работы: 'development' | 'production'
NODE_ENV=development

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# Хост базы данных
DB_HOST=localhost

# Порт базы данных
DB_PORT=5432

# Имя базы данных
DB_NAME=pfm

# Имя пользователя базы данных
DB_USERNAME=postgres

# Пароль пользователя базы данных
DB_PASSWORD=postgres

# ===========================================
# JWT CONFIGURATION
# ===========================================
# Секретный ключ для подписи JWT токенов
# В production обязательно изменить на сложный случайный ключ
JWT_SECRET=your-secret-key-change-in-production

# Ключи для access и refresh токенов
ACCESS_TOKEN_SECRET=access-secret-key-change-in-production
REFRESH_TOKEN_SECRET=refresh-secret-key-change-in-production

# Время жизни access токена (в секундах)
JWT_EXPIRES_IN=3600

# Время жизни refresh токена (в секундах)
JWT_REFRESH_EXPIRES_IN=604800

# ===========================================
# CORS CONFIGURATION
# ===========================================
# Разрешенные источники для CORS (через запятую)
# Для development можно использовать *
CORS_ORIGIN=*

# ===========================================
# API CONFIGURATION
# ===========================================
# Базовый URL API (используется для формирования ссылок)
# API_BASE_URL=http://localhost:8080
